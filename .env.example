# Local Python development
DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
TIME_ZONE=Europe/London

# GitHub App authentication (recommended)
GITHUB_AUTH_MODE=app
GITHUB_APP_ID=
# Coolify supports this as a multiline secret environment variable.
GITHUB_APP_PRIVATE_KEY=
# Recommended for Coolify: Base64-encode the full PEM, including header/footer.
GITHUB_APP_PRIVATE_KEY_BASE64=
# Optional file alternative for non-Coolify deployments.
GITHUB_APP_PRIVATE_KEY_PATH=

# Simpler single-user alternative. Keep it only on the server.
# GITHUB_AUTH_MODE=token
# GITHUB_TOKEN=github_pat_xxx

MAX_PUSH_FILES=100
MAX_FILE_BYTES=2097152
MAX_REQUEST_BYTES=16777216

# Coolify / production overrides
# APP_URL=https://git-gateway.example.com
# DATABASE_URL=postgresql://user:password@db:5432/aigitgateway
# ALLAUTH_TRUSTED_PROXY_COUNT=1
# SECURE_HSTS_SECONDS=31536000

# Startup controls
MIGRATE_ON_START=1
MIGRATION_MAX_ATTEMPTS=12
